{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "App": {
    "Name": "CIPP",
    "ReadinessMode": "HttpReady",
    "KestrelTimeoutSeconds": 660,
    "FileLogging": {
      "LogLevel": "Information"
    },
    "Setup": {
      "Enabled": true,
      "AuthAppDisplayName": "CIPP-SSO",
      "UnauthenticatedClientAction": "AllowAnonymous",
      "ExcludedPaths": [
        "/api/PublicPing",
        "/api/PublicWebhooks",
        "/api/setup/*",
        "/authredirect",
        "/LogoutRedirect",
        "/404",
        "/_next/static/*",
        "/assets/*",
        "/favicon.ico",
        "/apple-touch-icon.png",
        "/robots.txt",
        "/manifest.json",
        "/version.json"
      ],
      "KeyVaultName": "auto"
    },
    "Worker": {
      "HttpPoolSize": 6,
      "BgPoolSize": 8,
      "SkuProfiles": [
        { "SkuEnv": "WEBSITE_SKU", "Sku": "Basic",     "Cpu": 1, "HttpPoolSize": 2, "BgPoolSize": 2 },
        { "SkuEnv": "WEBSITE_SKU", "Sku": "Basic",     "Cpu": 2, "HttpPoolSize": 6, "BgPoolSize": 8 },
        { "SkuEnv": "WEBSITE_SKU", "Sku": "Basic",     "Cpu": 4, "HttpPoolSize": 8, "BgPoolSize": 12 },
        { "SkuEnv": "WEBSITE_SKU", "Sku": "PremiumV3", "Cpu": 1, "HttpPoolSize": 6, "BgPoolSize": 8 },
        { "SkuEnv": "WEBSITE_SKU", "Sku": "PremiumV3", "Cpu": 2, "HttpPoolSize": 8, "BgPoolSize": 12 }
      ],
      "HttpTimeoutSeconds": 600,
      "BgTimeoutSeconds": 1200,
      "RecycleAfterInvocations": 1000,
      "RootPathVars": [
        "CIPPRootPath",
        "CIPPRoot"
      ],
      "EnvVars": {
        "CIPPNG": "true",
        "CRAFT_ALLOWED_MODULES": "CIPPCore,CIPPStandards,CIPPAlerts,CIPPTests,CIPPDB,CippExtensions,DNSHealth,CIPPActivityTriggers"
      },
      "WarmupMode": "AfterReady",
      "WarmupScripts": [
        "Initialize-CIPPAuth",
        "Initialize-CIPPTimezone",
        "if ($env:ApplicationID) { $null = Get-Tenants -IncludeErrors }"
      ],
      "SharedAssemblies": [],
      "ModuleInjections": [
        {
          "Module": "CIPPCore",
          "Variable": "classictoken",
          "CacheKey": "ClassicTokenCache"
        }
      ],
      "PostInitScripts": [],
      "HttpModules": [
        "CIPPCore",
        "CIPPHTTP",
        "AzBobbyTables"
      ],
      "BgModules": [
        "CIPPCore",
        "CIPPActivityTriggers",
        "AzBobbyTables"
      ],
      "JsonPreloads": [
        {
          "File": "Config/function-permissions.json",
          "Variable": "CIPPFunctionPermissions",
          "Scope": "global",
          "AsHashtable": true
        },
        {
          "File": "Config/cipp-roles.json",
          "Variable": "CIPPBaseRoles",
          "Scope": "global",
          "AsHashtable": false
        }
      ]
    },
    "Auth": {
      "UserTableName": "allowedUsers",
      "AllowAllTenantUsers": true,
      "MeEndpointFunction": "me",
      "MeEndpointHandler": "New-CippCoreRequest"
    },
    "Scheduler": {
      "ConfigFile": "Config/CIPPTimers.json",
      "CheckIntervalSeconds": 30,
      "ApplyTZOffset": false,
      "Timezone": ""
    },
    "Orchestrator": {
      "TablePrefix": "CippOrchestrator"
    },
    "Cache": {
      "MaxEntries": 1000,
      "DefaultTtlSeconds": 600,
      "InvalidateParam": "InvalidateCIPPCache",
      "ScopeParam": "tenantFilter",
      "EndpointTtl": {}
    },
    "Scripts": {
      "HttpModules": [
        "CIPPHTTP"
      ],
      "HttpHandler": "New-CippCoreRequest",
      "BackgroundScriptDirs": [
        "Modules/CIPPCore/Public/Entrypoints/Timer Functions",
        "Modules/CIPPCore/Public/Entrypoints/Orchestrator Functions"
      ],
      "PermissionExtraction": {
        "Enabled": true,
        "Modules": [
          "CIPPHTTP"
        ],
        "OutputFile": "Config/function-permissions.json"
      }
    }
  }
}